{
  "name": "frida-mobile-mcp",
  "version": "0.2.0",
  "description": "Mobile Frida MCP Server - AI-powered mobile app exploration and testing via Frida instrumentation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "frida-mobile-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "frida",
    "mcp",
    "mobile",
    "android",
    "ios",
    "security",
    "instrumentation",
    "reverse-engineering"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@toon-format/toon": "^2.1.0",
    "commander": "^12.0.0",
    "frida": "^17.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@mobilenext/mobile-mcp": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
